# Required: Bearer token for authenticating requests.
# Generate one by running this in your terminal: openssl rand -hex 32
API_TOKEN=

# Optional: Max ms to wait for Table B callback (default: 300000 = 5 min)
# TIMEOUT_MS=300000

# Optional: Max concurrent pending bridge requests (default: 100)
# MAX_PENDING=100

# Optional: Server port (default: 3000)
# PORT=3000
